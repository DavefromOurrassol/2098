  - slug: arctique_nordark
    nom: Arctique Nordark
    niveau: 1
    type: territoire_autonome
    parent: null
    origine_reelle:
    - entite: Norvège
      type_entite: pays
      portion: null
    - entite: Suède
      type_entite: pays
