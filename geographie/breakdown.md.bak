  - slug: arc_eurasien_central
    nom: Arc Eurasien Central
    niveau: 1
    type: zone_sinistree
    parent: null
    origine_reelle:
    - entite: Russie
      type_entite: pays
      portion: null
    - entite: Kazakhstan
      type_entite: pays
