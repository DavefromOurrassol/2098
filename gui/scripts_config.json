[
  {
    "id": "enrich_minimal",
    "label": "Enrich minimal",
    "icon": "✨",
    "section": "generation",
    "script": "enrich_minimal.py",
    "description": "Enrichit les fichiers officialise_minimal via LLM",
    "requires": [],
    "options": [
      {
        "flag": "--all",
        "type": "checkbox",
        "label": "Tous les scénarios",
        "description": "Traite tous les scénarios disponibles",
        "default": false,
        "mutually_exclusive_with": "scenario"
      },
      {
        "flag": "--scenario",
        "type": "select",
        "label": "Scénario",
        "source": "config_scenarios",
        "default": "",
        "optional": true,
        "mutually_exclusive_with": "all"
      },
      {
        "flag": "--slug",
        "type": "slug_select",
        "label": "Slug (optionnel)",
        "slug_type": "instances",
        "optional": true
      },
      {
        "flag": "--limit",
        "type": "number",
        "label": "Limite",
        "description": "Nombre max de fichiers à traiter",
        "min": 1,
        "max": 426,
        "default": 10
      },
      {
        "flag": "--auto-cycle",
        "type": "checkbox",
        "label": "Auto-cycle",
        "description": "Enchaîne extract_phantom_slugs après enrichissement",
        "default": false
      },
      {
        "flag": "--dry-run",
        "type": "checkbox",
        "label": "Dry run",
        "description": "Simule sans écrire",
        "default": false
      }
    ],
    "yaml_files": [
      {
        "path": "instances_custom/needs_review_enrich.yaml",
        "label": "instances_custom/needs_review_enrich.yaml",
        "readonly": true
      }
    ]
  },
