      },
      {
        "flag": "--localisation",
        "type": "checkbox",
        "label": "Localisation",
        "description": "Force le scan de localisation",
        "default": false
      },
      {
        "flag": "--narrative",
        "short": "-n",
        "type": "checkbox",
        "label": "Cohérence narrative",
        "description": "Force le scan narratif (ignore cache mtime)",
        "default": false
      }
